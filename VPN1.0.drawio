          <mxGeometry height="30" width="200" y="200" as="geometry" />
        </mxCell>
        <mxCell id="EB0lFnT8MORgTNQC6fG5-38" parent="EB0lFnT8MORgTNQC6fG5-11" style="text;strokeColor=#005700;fillColor=#008a00;align=left;verticalAlign=middle;spacingLeft=4;spacingRight=4;overflow=hidden;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;rotatable=0;whiteSpace=wrap;html=1;fontColor=#ffffff;" value="2.打开网卡混杂模式,并创建一个原始套接字用于直接转发和监听获取IP和MAC是用户主机的数据包" vertex="1">
          <mxGeometry height="50" width="200" y="230" as="geometry" />
        </mxCell>

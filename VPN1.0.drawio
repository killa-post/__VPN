        <mxCell id="EB0lFnT8MORgTNQC6fG5-4" parent="1" style="swimlane;fontStyle=0;childLayout=stackLayout;horizontal=1;startSize=30;horizontalStack=0;resizeParent=1;resizeParentMax=0;resizeLast=0;collapsible=1;marginBottom=0;whiteSpace=wrap;html=1;fillColor=#e6d0de;gradientColor=#d5739d;strokeColor=#996185;" value="流程" vertex="1">
          <mxGeometry height="150" width="200" x="440" y="1050" as="geometry">
